# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Build / packaging artifacts
build/
dist/
*.egg-info/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# IDE / editor files
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Sensitive project runtime artifacts (must not be committed)
keys/
output/
*.pem
*.key
*.smsg
*.sfile
*.svault
*.ssig

# Local vendored dependencies (large, can be rebuilt by pip)
# Remove this line if you explicitly want to commit vendor dependencies.
vendor/

# Local temporary test data
tests/.tmp/
